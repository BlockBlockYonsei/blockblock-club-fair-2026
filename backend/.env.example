PORT=3001
HOST=0.0.0.0
# Optional. Set this when backend is behind a proxy/CDN so generated image URL is public.
PUBLIC_BASE_URL=
ALLOWED_ORIGINS=http://localhost:5173,https://blockblock-club-fair-2026.onrender.com
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
TRUST_PROXY=false

# Deployed Move package/object IDs
CONTRACT_PACKAGE_ID=0x...
MINT_CONFIG_OBJECT_ID=0x...

# suiprivkey... (ED25519). Keep this secret.
SPONSOR_PRIVATE_KEY=suiprivkey...

# 0.008 SUI (0.01 SUI split coin compatible with 120% min balance rule)
GAS_BUDGET_MIST=8000000

DEFAULT_NFT_NAME=BLOCKBLOCK NFT - 2026 Spring Yonsei Club Fair
DEFAULT_NFT_IMAGE_URL=https://placehold.co/1024x1024/png?text=BlockBlock+Booth

# Optional Supabase Storage for coin images
SUPABASE_URL=
SUPABASE_BUCKET_NAME=
SUPABASE_PUBLIC_BASE_URL=
SUPABASE_OBJECT_PREFIX=coin-list

# Rate limits
# If true: defaults become more relaxed for on-site booths.
RATE_LIMIT_RELAXED=false
RATE_LIMIT_GLOBAL_PER_MINUTE=300
RATE_LIMIT_IP_PER_MINUTE=120
RATE_LIMIT_SENDER_PER_10_MINUTES=2

# Sponsor gas coin pool tuning (for concurrent sponsored mints)
TARGET_CONCURRENT_MINTS=10
GAS_COIN_LOCK_MS=30000
GAS_COIN_FETCH_LIMIT=200
GAS_COIN_RESERVE_RETRIES=8
GAS_COIN_RESERVE_RETRY_DELAY_MS=250
# 12000 = 120% of GAS_BUDGET_MIST
GAS_COIN_MIN_BALANCE_BPS=12000

# Optional keepalive auth key for /api/keepalive (recommended for public deployments)
KEEPALIVE_KEY=
